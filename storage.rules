rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return firestore.get(/databases/ai-studio-37be4d1f-598c-4ff7-a83b-4064aa6d995e/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOf(storeId) {
      return isSignedIn() && getUserData().storeId == storeId;
    }

    // Attendance selfies
    match /attendance/{storeId}/{userId}/{fileName} {
      allow read: if isMemberOf(storeId);
      allow write: if request.auth.uid == userId && isMemberOf(storeId);
    }

    // Profile photos
    match /profiles/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Product photos
    match /products/{storeId}/{fileName} {
      allow read: if isMemberOf(storeId);
      allow write: if isMemberOf(storeId);
    }

    // Expense photos
    match /expenses/{storeId}/{fileName} {
      allow read: if isMemberOf(storeId);
      allow write: if isMemberOf(storeId);
    }
  }
}

